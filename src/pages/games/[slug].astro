---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GameDetail from '../../components/GameDetail.tsx';
import { getVisibleGames } from '../../data/games';
import { getSEO, getVideoGameSchema, getBreadcrumbSchema, getFAQSchema } from '../../utils/seo';

export function getStaticPaths() {
  const games = getVisibleGames();
  return games.map((game) => ({
    params: { slug: game.id },
    props: { game },
  }));
}

const { game } = Astro.props;

const seo = getSEO({
  title: `${game.title} — Wise Goose Games`,
  description: game.shortDescription,
  canonicalPath: `/games/${game.id}`,
  ogImage: game.steamAssets.header,
  structuredData: [
    getVideoGameSchema(game),
    getBreadcrumbSchema([
      { name: 'Home', path: '/' },
      { name: 'Games', path: '/games/' },
      { name: game.title, path: `/games/${game.id}/` },
    ]),
    ...(game.faq && game.faq.length > 0 ? [getFAQSchema(game.faq)] : []),
  ],
});
---

<BaseLayout {...seo}>
  <main>
    <GameDetail client:load game={game} />
  </main>
</BaseLayout>
