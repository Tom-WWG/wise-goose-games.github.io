---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GameCard from '../../components/GameCard.astro';
import { getVisibleGames } from '../../data/games';
import { getSEO } from '../../utils/seo';

const seo = getSEO({
  title: 'Games — Wise Goose Games',
  description: 'Explore our catalog of thoughtfully crafted games from Wise Goose Games.',
  canonicalPath: '/games',
});

const visibleGames = getVisibleGames();
---

<BaseLayout {...seo}>
  <main class="max-w-6xl mx-auto px-4 pt-32 pb-20">
    <h1 class="font-body font-bold text-4xl md:text-5xl text-center mb-4">Our Games</h1>
    <p class="font-body text-lg text-text/70 text-center max-w-xl mx-auto mb-12">
      Thoughtfully crafted interactive experiences. No filler.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {visibleGames.map((game) => (
        <a href={`/games/${game.id}`} class="no-underline">
          <GameCard game={game} />
        </a>
      ))}
    </div>

    {visibleGames.length <= 1 && (
      <p class="text-center text-text/50 font-mono text-sm mt-12">
        More games coming soon.
      </p>
    )}
  </main>
</BaseLayout>
