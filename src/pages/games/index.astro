---
import BaseLayout from '../../layouts/BaseLayout.astro';
import GameCard from '../../components/GameCard.astro';
import { getVisibleGames } from '../../data/games';
import { getSEO, getCollectionPageSchema, getBreadcrumbSchema, SITE_URL } from '../../utils/seo';

const seo = getSEO({
  title: 'Games — Wise Goose Games',
  description: 'Explore our catalog of thoughtfully crafted games from Wise Goose Games.',
  canonicalPath: '/games',
  structuredData: [
    getCollectionPageSchema('Games — Wise Goose Games', 'Explore our catalog of thoughtfully crafted games from Wise Goose Games.', `${SITE_URL}/games/`),
    getBreadcrumbSchema([
      { name: 'Home', path: '/' },
      { name: 'Games', path: '/games/' }
    ])
  ]
});

const visibleGames = getVisibleGames();
---

<BaseLayout {...seo}>
  <main class="max-w-6xl mx-auto px-4 pt-32 pb-20">
    <h1 class="sr-only">Games — Wise Goose Games</h1>
    <div class={`grid gap-8 ${visibleGames.length === 1 ? 'grid-cols-1 max-w-md mx-auto' : 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3'}`}>
      {visibleGames.map((game) => (
        <a href={`/games/${game.id}`} class="no-underline" data-enter>
          <GameCard game={game} />
        </a>
      ))}
    </div>

    {visibleGames.length <= 1 && (
      <p class="text-center text-text/50 font-mono text-sm mt-12" data-enter>
        More games coming soon.
      </p>
    )}
  </main>
</BaseLayout>
