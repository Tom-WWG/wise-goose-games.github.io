---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const SITE_URL = 'https://wisegoosegames.com';

const allParts = await getCollection('devlog', ({ data }) =>
  data.series === 'pathfinding' && !data.draft
);
const parts = allParts.sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0));

const rendered = await Promise.all(parts.map(p => p.render()));
---

<BaseLayout
  title="Advanced Pathfinding — Full Series — Wise Goose Games Devlog"
  description="The complete Advanced Pathfinding series: BFS foundations through multi-ghost regret scoring."
  canonical={`${SITE_URL}/devlog/pathfinding/`}
  ogUrl={`${SITE_URL}/devlog/pathfinding/`}
  ogImage={`${SITE_URL}/og-image.jpg`}
>
  <main class="devlog-article">
    <div class="devlog-article-container">
      <header class="devlog-article-header">
        <div class="devlog-meta-strip">
          <span class="devlog-article-date">
            <em>{parts[0]?.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}</em>
          </span>
          {parts[0]?.data.game && <span class="devlog-article-game">{parts[0].data.game}</span>}
        </div>
        <h1>Advanced Pathfinding</h1>
        <p class="devlog-article-subtitle">Complete series — all {parts.length} parts</p>
      </header>

      {rendered.map(({ Content }, i) => (
        <article class="devlog-prose series-part-block" data-part={i + 1}>
          <Content />
          {i < rendered.length - 1 && <div class="series-part-divider" />}
        </article>
      ))}

      <nav class="series-nav-footer" aria-label="Series parts index">
        <p>Read individual parts:</p>
        <ul>
          {parts.map(p => (
            <li>
              <a href={`/devlog/${p.slug}/`}>{p.data.title}</a>
              {p.data.subtitle && <span> — {p.data.subtitle}</span>}
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </main>
</BaseLayout>

<style is:global>
  /* ── Shared article layout (duplicated from [slug].astro until extracted to shared CSS) ── */
  .devlog-article-container {
    max-width: 760px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  .devlog-article-header {
    margin-bottom: 5rem;
    border-bottom: 2px solid var(--border-strong);
    padding-bottom: 2rem;
  }
  .devlog-meta-strip {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border-medium);
    padding-bottom: 1rem;
    margin-bottom: 2rem;
  }
  .devlog-article-date {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--text-muted);
  }
  .devlog-article-game {
    background: var(--accent);
    color: var(--bg-primary);
    padding: 0.2rem 0.6rem;
    font-weight: 800;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .devlog-article-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    color: var(--text-primary);
    margin-top: 0;
    text-transform: uppercase;
    letter-spacing: -1px;
    line-height: 1.1;
  }
  .devlog-article-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-top: 0.75rem;
  }

  .devlog-prose { color: #E0E0E0; line-height: 1.8; }

  .devlog-prose h2 {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 3.5rem 0 1rem;
    border-left: 2px solid var(--accent);
    padding-left: 1rem;
  }

  .devlog-prose h3 {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 2.5rem 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }

  .devlog-prose h2 + h3 {
    margin-top: 0.5rem;
  }

  .devlog-prose p {
    margin-top: 0;
    margin-bottom: 1.75rem;
  }

  .devlog-prose h2 + p,
  .devlog-prose h3 + p {
    margin-top: 0;
  }

  .devlog-prose p + pre {
    margin-top: 1.5rem;
  }

  .devlog-prose pre + p {
    margin-top: 1.5rem;
  }

  .devlog-prose strong {
    color: var(--text-primary);
    font-weight: 700;
  }
  .devlog-prose em {
    font-style: italic;
    color: #C0C0C0;
  }

  .devlog-prose ul {
    list-style: none;
    padding: 0;
    margin: 0 0 1.75rem;
  }
  .devlog-prose ul li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.6rem;
    line-height: 1.8;
  }
  .devlog-prose ul li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }
  .devlog-prose ol {
    padding-left: 1.5rem;
    margin: 0 0 1.75rem;
  }
  .devlog-prose ol li {
    margin-bottom: 0.6rem;
    line-height: 1.8;
  }

  .devlog-prose pre {
    background: #0F0F0F;
    border: 1px solid var(--border-strong);
    border-left: 4px solid var(--accent);
    padding: 1.5rem;
    overflow-x: auto;
    margin: 2.5rem 0;
    font-size: 0.85rem;
    position: relative;
  }
  .devlog-prose pre::before {
    content: "SOURCE_LOG // RAW_DATA";
    display: block;
    font-size: 9px;
    color: var(--text-muted);
    margin-bottom: 1rem;
    letter-spacing: 2px;
  }
  .devlog-prose code {
    font-size: 0.85em;
    background: var(--bg-elevated);
    padding: 0.15em 0.4em;
    color: var(--accent);
  }
  .devlog-prose pre code { background: none; padding: 0; color: inherit; }

  .devlog-prose img { width: 100%; margin: 1.5rem 0; }

  .devlog-prose hr {
    border: none;
    height: 8px;
    background-image: repeating-linear-gradient(
      45deg,
      var(--border-strong),
      var(--border-strong) 1px,
      transparent 1px,
      transparent 10px
    );
    margin: 5rem 0;
  }

  .devlog-prose table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  .devlog-prose th, .devlog-prose td {
    padding: 0.6rem 1rem;
    border: 1px solid var(--border-medium);
    text-align: left;
  }
  .devlog-prose th { color: var(--text-primary); background: var(--bg-elevated); }

  .devlog-prose .draft-stub {
    font-style: italic;
    color: var(--text-muted);
    border-left: 2px solid var(--border-strong);
    padding-left: 1rem;
    margin-bottom: 1.75rem;
    font-size: 0.85rem;
    letter-spacing: 0.3px;
  }

  .devlog-prose .grid-anim-container {
    border: 2px solid var(--border-strong);
    border-radius: 0;
    margin: 3rem 0;
  }
  .devlog-prose .grid-anim-container::after {
    content: "● LIVE SIMULATION";
    display: block;
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--accent);
    padding: 0.5rem 0;
    border-top: 1px solid var(--border-medium);
    margin-top: 0.25rem;
  }

  @media (min-width: 1200px) {
    .devlog-article-container {
      max-width: 1020px;
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 0 3rem;
    }

    .devlog-article-header,
    .devlog-prose,
    .series-nav-footer {
      grid-column: 2;
    }

    .devlog-prose h2 {
      position: relative;
    }
    .devlog-prose h2::before {
      content: "SECTION //";
      position: absolute;
      left: calc(-3rem - 200px);
      width: 200px;
      text-align: right;
      font-size: 9px;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: 2px;
      top: 0.35rem;
    }

    .devlog-prose .grid-anim-container {
      margin-left: -2rem;
      margin-right: -2rem;
    }
  }

  /* ── Combined page: part dividers and footer nav ── */
  .series-part-divider {
    height: 8px;
    background-image: repeating-linear-gradient(
      45deg,
      var(--border-strong),
      var(--border-strong) 1px,
      transparent 1px,
      transparent 10px
    );
    margin: 5rem 0;
  }

  .series-nav-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-medium);
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .series-nav-footer p {
    margin-bottom: 0.5rem;
  }

  .series-nav-footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .series-nav-footer li {
    padding: 0.25rem 0;
  }

  .series-nav-footer a {
    color: var(--accent);
    text-decoration: none;
  }

  .series-nav-footer a:hover {
    text-decoration: underline;
  }
</style>
