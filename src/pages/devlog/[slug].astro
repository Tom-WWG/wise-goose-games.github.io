---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const SITE_URL = 'https://wisegoosegames.com';

export async function getStaticPaths() {
  const entries = await getCollection('devlog', ({ data }) => !data.draft);

  return entries.map(entry => {
    let seriesPrev = null;
    let seriesNext = null;
    if (entry.data.series && entry.data.seriesPart) {
      const siblings = entries
        .filter(e => e.data.series === entry.data.series)
        .sort((a, b) => (a.data.seriesPart ?? 0) - (b.data.seriesPart ?? 0));
      const idx = siblings.findIndex(e => e.slug === entry.slug);
      seriesPrev = idx > 0 ? siblings[idx - 1] : null;
      seriesNext = idx < siblings.length - 1 ? siblings[idx + 1] : null;
    }

    return {
      params: { slug: entry.slug },
      props: { entry, seriesPrev, seriesNext },
    };
  });
}

const { entry, seriesPrev, seriesNext } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout
  title={`${entry.data.title} — Wise Goose Games Devlog`}
  description={entry.data.subtitle ?? `${entry.data.title} — Wise Goose Games devlog`}
  canonical={`${SITE_URL}/devlog/${entry.slug}/`}
  ogUrl={`${SITE_URL}/devlog/${entry.slug}/`}
  ogImage={`${SITE_URL}/og-image.jpg`}
>
  <main class="devlog-article">
    <div class="devlog-article-container">
      <header class="devlog-article-header">
        <div class="devlog-meta-strip">
          <span class="devlog-article-date">
            {entry.data.date.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
          </span>
          {entry.data.game && <span class="devlog-article-game">{entry.data.game}</span>}
        </div>
        <h1>{entry.data.title}</h1>
        {entry.data.subtitle && <p class="devlog-article-subtitle">{entry.data.subtitle}</p>}
      </header>

      {entry.data.series && (
        <nav class="series-nav">
          <div class="series-nav-label">
            <span class="series-tag">SERIES</span>
            <span class="series-title-text">{entry.data.seriesTitle}</span>
            <span class="series-part-count">Part {entry.data.seriesPart} of {entry.data.seriesTotal}</span>
          </div>
          <div class="series-nav-links">
            {seriesPrev
              ? <a class="series-nav-prev" href={`/devlog/${seriesPrev.slug}/`}>← {seriesPrev.data.title}</a>
              : <span class="series-nav-prev series-nav-disabled" />
            }
            <a class="series-nav-all" href={`/devlog/${entry.data.series}/`}>Full Series</a>
            {seriesNext
              ? <a class="series-nav-next" href={`/devlog/${seriesNext.slug}/`}>{seriesNext.data.title} →</a>
              : <span class="series-nav-next series-nav-disabled" />
            }
          </div>
        </nav>
      )}

      <article class="devlog-prose">
        <Content />
      </article>

      {entry.data.series && (
        <nav class="series-nav">
          <div class="series-nav-label">
            <span class="series-tag">SERIES</span>
            <span class="series-title-text">{entry.data.seriesTitle}</span>
            <span class="series-part-count">Part {entry.data.seriesPart} of {entry.data.seriesTotal}</span>
          </div>
          <div class="series-nav-links">
            {seriesPrev
              ? <a class="series-nav-prev" href={`/devlog/${seriesPrev.slug}/`}>← {seriesPrev.data.title}</a>
              : <span class="series-nav-prev series-nav-disabled" />
            }
            <a class="series-nav-all" href={`/devlog/${entry.data.series}/`}>Full Series</a>
            {seriesNext
              ? <a class="series-nav-next" href={`/devlog/${seriesNext.slug}/`}>{seriesNext.data.title} →</a>
              : <span class="series-nav-next series-nav-disabled" />
            }
          </div>
        </nav>
      )}
    </div>
  </main>
</BaseLayout>

<!-- DEV TOOL: color-space toggle — remove before shipping -->
<div id="gamut-pill">
  <span id="gamut-label">P3</span>
  <button id="gamut-btn" aria-label="Toggle SDR / P3">SDR ⇄ P3</button>
</div>

<style>
  #gamut-pill {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 9999;
    display: flex;
    align-items: center;
    gap: 8px;
    background: #111;
    border: 1px solid #333;
    border-radius: 20px;
    padding: 6px 14px 6px 10px;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.5px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.6);
    user-select: none;
  }
  #gamut-label {
    color: #00eba0;
    min-width: 2.2ch;
    text-align: center;
    font-variant-numeric: tabular-nums;
  }
  .force-sdr #gamut-label { color: #888; }
  #gamut-btn {
    background: none;
    border: 1px solid #333;
    color: #666;
    border-radius: 10px;
    padding: 2px 10px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s;
  }
  #gamut-btn:hover { border-color: #555; color: #aaa; }
</style>

<script>
  const btn = document.getElementById('gamut-btn');
  const label = document.getElementById('gamut-label');
  btn?.addEventListener('click', () => {
    document.documentElement.classList.toggle('force-sdr');
    const isSDR = document.documentElement.classList.contains('force-sdr');
    label.textContent = isSDR ? 'SDR' : 'P3';
  });
</script>
<!-- /DEV TOOL -->

<style is:global>
  .devlog-article-container {
    max-width: 760px;
    margin: 0 auto;
    padding: 4rem 1.5rem;
  }

  /* ── P2: Brutalist masthead ── */
  .devlog-article-header {
    margin-bottom: 5rem;
    border-bottom: 2px solid var(--border-strong);
    padding-bottom: 2rem;
  }
  .devlog-meta-strip {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--border-medium);
    padding-bottom: 1rem;
    margin-bottom: 2rem;
  }
  .devlog-article-date {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: 1.1rem;
    color: var(--text-muted);
  }
  .devlog-article-game {
    background: var(--accent);
    color: var(--bg-primary);
    padding: 0.2rem 0.6rem;
    font-weight: 800;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .devlog-article-header h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 800;
    color: var(--text-primary);
    margin-top: 0;
    text-transform: uppercase;
    letter-spacing: -1px;
    line-height: 1.1;
  }
  .devlog-article-subtitle {
    font-size: 1.1rem;
    color: var(--text-secondary);
    margin-top: 0.75rem;
  }

  /* ── P1: Body copy contrast ── */
  .devlog-prose { color: #E0E0E0; line-height: 1.8; }

  /* ── P3: H2 — left accent border instead of underline ── */
  .devlog-prose h2 {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 3.5rem 0 1rem;
    border-left: 2px solid var(--accent);
    padding-left: 1rem;
  }

  /* ── P3: H3 — uppercase UI label treatment ── */
  .devlog-prose h3 {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 2.5rem 0 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }

  /* When h3 directly follows h2 it's a sub-label, not a new section — tighten the gap */
  .devlog-prose h2 + h3 {
    margin-top: 0.5rem;
  }

  /* ── Paragraphs ── */
  .devlog-prose p {
    margin-top: 0;
    margin-bottom: 1.75rem;
  }

  /* First paragraph right after a heading — margin already handled by heading's margin-bottom */
  .devlog-prose h2 + p,
  .devlog-prose h3 + p {
    margin-top: 0;
  }

  /* Tighten the gap when a paragraph leads directly into a code block */
  .devlog-prose p + pre {
    margin-top: 1.5rem;
  }

  /* Give a paragraph room to breathe after a code block */
  .devlog-prose pre + p {
    margin-top: 1.5rem;
  }

  /* ── Inline text styles ── */
  .devlog-prose strong {
    color: var(--text-primary);
    font-weight: 700;
  }
  .devlog-prose em {
    font-style: italic;
    color: #C0C0C0;
  }

  /* ── Lists ── */
  .devlog-prose ul {
    list-style: none;
    padding: 0;
    margin: 0 0 1.75rem;
  }
  .devlog-prose ul li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.6rem;
    line-height: 1.8;
  }
  /* Em-dash bullet in accent colour */
  .devlog-prose ul li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--accent);
    font-weight: 700;
  }
  .devlog-prose ol {
    padding-left: 1.5rem;
    margin: 0 0 1.75rem;
  }
  .devlog-prose ol li {
    margin-bottom: 0.6rem;
    line-height: 1.8;
  }

  /* ── P4: Blueprint code blocks ── */
  .devlog-prose pre {
    background: #0F0F0F;
    border: 1px solid var(--border-strong);
    border-left: 4px solid var(--accent);
    padding: 1.5rem;
    overflow-x: auto;
    margin: 2.5rem 0;
    font-size: 0.85rem;
    position: relative;
  }
  .devlog-prose pre::before {
    content: "SOURCE_LOG // RAW_DATA";
    display: block;
    font-size: 9px;
    color: var(--text-muted);
    margin-bottom: 1rem;
    letter-spacing: 2px;
  }
  .devlog-prose code {
    font-size: 0.85em;
    background: var(--bg-elevated);
    padding: 0.15em 0.4em;
    color: var(--accent);
  }
  .devlog-prose pre code { background: none; padding: 0; color: inherit; }

  /* ── P1: Images — no radius ── */
  .devlog-prose img { width: 100%; margin: 1.5rem 0; }

  /* ── P5: Industrial HR dividers ── */
  .devlog-prose hr {
    border: none;
    height: 8px;
    background-image: repeating-linear-gradient(
      45deg,
      var(--border-strong),
      var(--border-strong) 1px,
      transparent 1px,
      transparent 10px
    );
    margin: 5rem 0;
  }

  .devlog-prose table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }
  .devlog-prose th, .devlog-prose td {
    padding: 0.6rem 1rem;
    border: 1px solid var(--border-medium);
    text-align: left;
  }
  .devlog-prose th { color: var(--text-primary); background: var(--bg-elevated); }

  /* ── Draft stubs — visible placeholder for in-progress copy ── */
  .devlog-prose .draft-stub {
    font-style: italic;
    color: var(--text-muted);
    border-left: 2px solid var(--border-strong);
    padding-left: 1rem;
    margin-bottom: 1.75rem;
    font-size: 0.85rem;
    letter-spacing: 0.3px;
  }

  /* ── P7: Animation frames ── */
  /* Higher specificity overrides grid-animation.css border/radius on container */
  .devlog-prose .grid-anim-container {
    border: 2px solid var(--border-strong);
    border-radius: 0;
    margin: 3rem 0;
  }
  /* "● LIVE SIMULATION" footer strip — renders as last flex child in the column */
  .devlog-prose .grid-anim-container::after {
    content: "● LIVE SIMULATION";
    display: block;
    font-size: 9px;
    letter-spacing: 2px;
    color: var(--accent);
    padding: 0.5rem 0;
    border-top: 1px solid var(--border-medium);
    margin-top: 0.25rem;
  }

  /* ── P6: Asymmetric gutter — wide viewports only ── */
  @media (min-width: 1200px) {
    .devlog-article-container {
      max-width: 1020px;
      display: grid;
      grid-template-columns: 200px 1fr;
      gap: 0 3rem;
    }

    /* Both header and prose live in the right (content) column */
    .devlog-article-header,
    .devlog-prose {
      grid-column: 2;
    }

    /* h2 pulls a "SECTION //" label back into the left gutter */
    .devlog-prose h2 {
      position: relative;
    }
    .devlog-prose h2::before {
      content: "SECTION //";
      position: absolute;
      left: calc(-3rem - 200px);
      width: 200px;
      text-align: right;
      font-size: 9px;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: 2px;
      top: 0.35rem;
    }

    /* Animations bleed slightly past the text column at desktop */
    .devlog-prose .grid-anim-container {
      margin-left: -2rem;
      margin-right: -2rem;
    }
  }

  /* ── Series navigation ── */
  .series-nav {
    border: 1px solid var(--border-medium);
    padding: 1rem 1.25rem;
    margin: 2rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .series-nav-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .series-tag {
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 2px;
    color: var(--bg-primary);
    background: var(--accent);
    padding: 0.2rem 0.5rem;
    text-transform: uppercase;
  }

  .series-title-text {
    font-weight: 700;
    color: var(--text-primary);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .series-part-count {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-left: auto;
  }

  .series-nav-links {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.85rem;
  }

  .series-nav-prev { text-align: left; }
  .series-nav-all  { text-align: center; color: var(--accent); font-weight: 700; font-size: 0.8rem; letter-spacing: 1px; text-transform: uppercase; white-space: nowrap; }
  .series-nav-next { text-align: right; }

  .series-nav-links a { color: var(--text-secondary); text-decoration: none; transition: color 0.15s; }
  .series-nav-links a:hover { color: var(--text-primary); }
  .series-nav-disabled { display: block; }
</style>
