---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSEO, getOrganizationSchema } from '../utils/seo';
import { games } from '../data/games';
import Hero from '../components/Hero.astro';

const game = games[0];

const seo = getSEO({
  title: 'Wise Goose Games — Thoughtfully Crafted Games',
  description: 'Wise Goose Games makes thoughtfully crafted indie games. Play Pathways & Poltergeists — a spatial puzzle adventure on Steam, iOS, and Android.',
  canonicalPath: '/',
  structuredData: getOrganizationSchema(),
});
---

<BaseLayout {...seo}>
  <link slot="head" rel="preload" as="image" href="/pp-assets/HeroCapsule.webp" imagesrcset="/pp-assets/HeroCapsule-640w.webp 640w, /pp-assets/HeroCapsule-1232w.webp 1232w, /pp-assets/HeroCapsule-2464w.webp 2464w, /pp-assets/HeroCapsule-3696w.webp 3696w" imagesizes="100vw" />
  <Hero game={game} headerImage="/pp-assets/HeroCapsule.webp" />
</BaseLayout>
