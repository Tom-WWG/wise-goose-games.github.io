---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSEO, getOrganizationSchema } from '../utils/seo';
import { games } from '../data/games';
import Hero from '../components/Hero.astro';

const game = games[0];

const seo = getSEO({
  title: 'Wise Goose Games — Thoughtfully Crafted Games',
  description: 'Wise Goose Games is a California-based independent studio creating thoughtfully designed interactive experiences that respect players\' intelligence.',
  canonicalPath: '/',
  structuredData: getOrganizationSchema(),
});
---

<BaseLayout {...seo}>
  <Hero game={game} headerImage="/pp-assets/HeroCapsule.webp" />
</BaseLayout>
