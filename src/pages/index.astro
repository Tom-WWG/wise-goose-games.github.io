---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSEO, getOrganizationSchema } from '../utils/seo';
import { games } from '../data/games';
import Hero from '../components/Hero.tsx';
import FeaturedGame from '../components/FeaturedGame.tsx';

const game = games[0];

const seo = getSEO({
  title: 'Wise Goose Games — Thoughtfully Crafted Games',
  description: 'Wise Goose Games LLC is a two-person independent game studio based in California, committed to creating thoughtfully designed interactive experiences that respect players\' intelligence.',
  canonicalPath: '/',
  structuredData: getOrganizationSchema(),
});
---

<BaseLayout {...seo}>
  <Hero client:load steamUrl={game.platforms.steam.url} headerImage="/pp-assets/screenshot-1.png" />
  <FeaturedGame client:visible game={game} />

  <!-- Studio one-liner -->
  <section class="py-12 md:py-16 px-6 text-center">
    <p class="font-body text-text/60 text-base max-w-lg mx-auto">
      Two-person indie studio in California. Hand-crafted puzzles, no filler.
    </p>
  </section>
</BaseLayout>
