---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getSEO } from '../utils/seo';

const seo = getSEO({
  title: 'Page Not Found | Wise Goose Games',
  description: 'The page you are looking for does not exist.',
  canonicalPath: '/404',
  noindex: true,
});
---

<BaseLayout {...seo}>
  <main class="max-w-6xl mx-auto px-4 pt-32 pb-20 text-center min-h-[60vh] flex flex-col items-center justify-center">
    <h1 class="font-drama italic text-8xl md:text-9xl text-accent mb-4">404</h1>
    <p class="font-body text-xl text-text/70 mb-8">This page wandered off into the fog.</p>
    <a href="/" class="btn-accent">
      <span class="bg-slide"></span>
      Back to Home
    </a>
  </main>
</BaseLayout>
