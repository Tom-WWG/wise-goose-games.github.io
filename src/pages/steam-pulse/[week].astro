---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getArticleSchema, getBreadcrumbSchema } from '../../utils/seo';
import SteamPulseBarChart from '../../components/SteamPulseBarChart.astro';
import SteamPulseTrendChart from '../../components/SteamPulseTrendChart.astro';
import SteamPulseFAQ from '../../components/SteamPulseFAQ.astro';

export async function getStaticPaths() {
  const entries = await getCollection('steam-pulse');
  return entries.map(entry => ({
    params: { week: `week-${entry.data.week}` },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const SITE_URL = 'https://wisegoosegames.com';

function extractSection(body: string, heading: string): string {
  const match = body.match(new RegExp(`## ${heading}\\n([\\s\\S]*?)(?=\\n## |$)`));
  return match?.[1]?.trim() ?? '';
}

const weeklyTake = extractSection(entry.body, 'WEEKLY TAKE');
const trendTake = extractSection(entry.body, 'TREND TAKE');
const siteSubtitle = extractSection(entry.body, 'SITE SUBTITLE');

// Build BarItem arrays for SteamPulseBarChart
const risingTagNames = new Set(d.rising.map(r => r.tag));

const genreBarItems = d.genres.map(g => ({
  name: g.name,
  score: g.score,
  trend: g.trend,
  topGames: g.top_games,
  gameCount: g.game_count,
}));

const tagBarItems = d.tags.map(t => ({
  name: t.name,
  score: t.score,
  trend: t.trend,
  isNew: risingTagNames.has(t.name) && t.trend === 'rising',
  topGames: t.top_games,
  gameCount: t.game_count,
}));

// Build TrendSeries arrays for SteamPulseTrendChart
// Trend-shaped history: rising curves up, declining falls, stable oscillates
function trendHistory(
  finalScore: number,
  trend: 'rising' | 'stable' | 'declining',
  seed: number
): Array<{ weekLabel: string; score: number }> {
  const labels = ['01/29', '02/05', '02/12', '02/19', '02/26', '03/05', '03/12', d.period];

  return labels.map((weekLabel, i) => {
    const progress = i / (labels.length - 1); // 0.0 at start, 1.0 at end
    let baseScore: number;

    if (trend === 'rising') {
      // Starts ~22pts below final, curves up to finalScore
      baseScore = finalScore - Math.round((1 - progress) * 22);
    } else if (trend === 'declining') {
      // Starts ~18pts above final, falls to finalScore
      baseScore = finalScore + Math.round((1 - progress) * 18);
    } else {
      // Always produce a visible oscillation — vary phase and amplitude by seed
      const phase = (seed % 5) * 0.4;
      const amplitude = 3 + (seed % 4);
      const wave = Math.sin(progress * Math.PI * 2 + phase) * amplitude;
      baseScore = finalScore + Math.round(wave);
    }

    // Deterministic noise: small per-point variation
    const noise = ((seed * (i + 3)) % 7) - 3;
    return {
      weekLabel,
      score: Math.max(0, Math.min(100, baseScore + noise)),
    };
  });
}

const genreSeries = d.genres.map((g, idx) => ({
  name: g.name,
  currentScore: g.score,
  trend: g.trend,
  history: trendHistory(g.score, g.trend, idx * 7 + g.score),
}));

const tagSeries = d.tags.map((t, idx) => ({
  name: t.name,
  currentScore: t.score,
  trend: t.trend,
  history: trendHistory(t.score, t.trend, idx * 11 + t.score),
}));

const weekLabel = `Week ${d.week}`;
const weekLabelDisplay = `WEEK ${d.week} · ${d.period}`;

const weekUrl = `${SITE_URL}/steam-pulse/week-${d.week}/`;
const articleDescription = d.description
  ?? `Week ${d.week}: ${d.total_releases} Steam releases, ${d.hit_rate}% hit rate.`;
const articleSchema = getArticleSchema({
  headline: `Steam Pulse Week ${d.week}: ${d.period}`,
  description: articleDescription,
  datePublished: d.date.toISOString().split('T')[0],
  url: weekUrl,
});
const breadcrumbSchema = getBreadcrumbSchema([
  { name: 'Home', path: '/' },
  { name: 'Steam Pulse', path: '/steam-pulse/' },
  { name: `Week ${d.week}`, path: `/steam-pulse/week-${d.week}/` },
]);
---

<BaseLayout
  title={`Steam Pulse Week ${d.week}: ${d.period} | Wise Goose Games`}
  description={articleDescription}
  canonical={weekUrl}
  ogUrl={weekUrl}
  ogImage={`${SITE_URL}/og-image.jpg`}
  structuredData={[breadcrumbSchema, articleSchema]}
>
  <main class="sp-page">
    <div class="sp-container">

      <!-- Page Header -->
      <header class="sp-page-header" data-enter>
        <div class="sp-page-header-top">
          <h1 class="sp-page-title">STEAM PULSE</h1>
          <span class="sp-page-week">{weekLabelDisplay}</span>
        </div>
        <div class="sp-page-rule"></div>
        <p class="sp-page-subtitle">"{siteSubtitle || 'Weekly Steam market insights for indie developers'}"</p>
      </header>

      <!-- Bar Chart Section -->
      <div class="sp-section" data-reveal>
        <a href="#faq-composite-score" class="sp-section-tag">THIS WEEK — COMPOSITE SCORE <span class="sp-metric-q">?</span></a>
        <SteamPulseBarChart
          week={weekLabel}
          hitRateDelta={d.hit_rate_delta}
          genres={genreBarItems}
          tags={tagBarItems}
        />
        <div class="sp-editorial">
          <span class="sp-editorial-label">WEEKLY TAKE</span>
          <p class="sp-editorial-text">{weeklyTake}</p>
        </div>
      </div>

      <!-- Trend Chart Section -->
      <div class="sp-section" data-reveal>
        <p class="sp-section-tag">WEEK OVER WEEK</p>
        <SteamPulseTrendChart
          week={weekLabel}
          genreSeries={genreSeries}
          tagSeries={tagSeries}
        />
        <div class="sp-editorial">
          <span class="sp-editorial-label">TREND TAKE</span>
          <p class="sp-editorial-text">{trendTake}</p>
        </div>
      </div>

      <!-- Market Pulse Strip -->
      <div class="sp-pulse-strip" data-enter>
        <div class="sp-pulse-card">
          <span class="sp-pulse-label">Total Releases</span>
          <span class="sp-pulse-value">{d.total_releases}</span>
        </div>
        <div class="sp-pulse-card">
          <a href="#faq-hit-rate" class="sp-pulse-label sp-metric-link">Hit Rate <span class="sp-metric-q">?</span></a>
          <div class="sp-pulse-value-row">
            <span class="sp-pulse-value">{d.hit_rate}%</span>
            <span class={`sp-pulse-delta ${d.hit_rate_delta >= 0 ? 'sp-pulse-delta--up' : 'sp-pulse-delta--down'}`}>
              {d.hit_rate_delta >= 0 ? '↑' : '↓'} {d.hit_rate_delta >= 0 ? '+' : ''}{d.hit_rate_delta}pts <a href="#faq-wow" class="sp-metric-link sp-wow-link">WoW</a>
            </span>
          </div>
        </div>
        <div class="sp-pulse-card sp-pulse-card--wide">
          <a href="#faq-classification" class="sp-pulse-label sp-metric-link">Breakdown <span class="sp-metric-q">?</span></a>
          <div class="sp-pulse-breakdown">
            <span class="sp-pulse-breakdown-item">
              <span class="sp-pulse-breakdown-num">{d.hit_count}</span>
              <a href="#faq-classification" class="sp-pulse-breakdown-tag sp-metric-link">Hits</a>
            </span>
            <span class="sp-pulse-breakdown-div">·</span>
            <span class="sp-pulse-breakdown-item">
              <span class="sp-pulse-breakdown-num">{d.promising_count}</span>
              <a href="#faq-classification" class="sp-pulse-breakdown-tag sp-metric-link">Promising</a>
            </span>
            <span class="sp-pulse-breakdown-div">·</span>
            <span class="sp-pulse-breakdown-item">
              <span class="sp-pulse-breakdown-num">{d.niche_count}</span>
              <a href="#faq-classification" class="sp-pulse-breakdown-tag sp-metric-link">Niche</a>
            </span>
          </div>
        </div>
      </div>

      <!-- Signal Cards Row -->
      <div class="sp-signals" data-reveal>
        <!-- Rising -->
        <div class="sp-signal-card sp-signal-card--rising">
          <div class="sp-signal-header">
            <a href="#faq-rising-saturating" class="sp-signal-title sp-metric-link">Rising <span class="sp-metric-q">?</span></a>
          </div>
          <ul class="sp-signal-list">
            {d.rising.map(item => (
              <li class="sp-signal-row">
                <span class="sp-signal-tag">{item.tag}</span>
                <span class="sp-signal-delta sp-signal-delta--up">+{item.delta}%</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Saturating -->
        <div class="sp-signal-card sp-signal-card--saturating">
          <div class="sp-signal-header">
            <a href="#faq-rising-saturating" class="sp-signal-title sp-metric-link">Saturating <span class="sp-metric-q">?</span></a>
          </div>
          <ul class="sp-signal-list">
            {d.saturating.map(item => (
              <li class="sp-signal-row">
                <span class="sp-signal-tag">{item.tag}</span>
                <span class="sp-signal-delta sp-signal-delta--down">−{Math.abs(item.delta)}%</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Emerging Niches -->
        <div class="sp-signal-card sp-signal-card--niches">
          <div class="sp-signal-header">
            <a href="#faq-emerging-niches" class="sp-signal-title sp-metric-link">Emerging Niches <span class="sp-metric-q">?</span></a>
          </div>
          <ul class="sp-signal-list">
            {d.niches.map(item => (
              <li class="sp-signal-row">
                <span class="sp-signal-tag">{item.tag}</span>
                <span class="sp-signal-niche">
                  <span class="sp-signal-niche-rate">{item.success_rate}%</span>
                  <span class="sp-signal-niche-count">({item.game_count} games)</span>
                </span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- FAQ -->
      <SteamPulseFAQ />

      <!-- Footer Attribution -->
      <footer class="sp-attribution" data-reveal>
        <p class="sp-attribution-text">
          Data sourced from Steamworks API · 7-day rolling averages · wisegoosegames.com/steam-pulse
        </p>
      </footer>

    </div>
  </main>
</BaseLayout>

<script>
  // Export mode: freeze animations until puppeteer recorder is ready
  if (new URLSearchParams(window.location.search).get('export') === '1') {
    document.documentElement.classList.add('export-freeze');
  }
</script>

<style is:global>
  .export-freeze [data-enter],
  .export-freeze [data-reveal] {
    opacity: 0;
    transform: translateY(8px);
    animation: none !important;
    transition: none !important;
  }
</style>

<style>
  .sp-page {
    background: var(--bg-primary);
    min-height: 100vh;
    padding-top: 6rem;
    padding-bottom: 5rem;
  }

  .sp-container {
    max-width: 860px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  /* ===== Page Header ===== */
  .sp-page-header {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sp-page-header-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .sp-page-title {
    font-family: 'Montserrat', sans-serif;
    font-size: clamp(2.25rem, 7vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    color: var(--text-primary);
    line-height: 1;
    margin: 0;
  }

  .sp-page-week {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .sp-page-rule {
    height: 2px;
    background: var(--accent);
    margin-bottom: 0.75rem;
  }

  .sp-page-subtitle {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(1.125rem, 3vw, 1.4rem);
    color: var(--text-secondary);
    margin: 0;
    line-height: 1.3;
  }

  /* ===== Market Pulse Strip ===== */
  .sp-pulse-strip {
    display: grid;
    grid-template-columns: 1fr 1fr 2fr;
    gap: 1px;
    background: var(--border-medium);
    border: 1px solid var(--border-medium);
  }

  @media (max-width: 560px) {
    .sp-pulse-strip {
      grid-template-columns: 1fr 1fr;
    }

    .sp-pulse-card--wide {
      grid-column: 1 / -1;
    }
  }

  .sp-pulse-card {
    background: var(--bg-elevated);
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sp-pulse-card--wide {
    background: var(--bg-elevated);
  }

  .sp-pulse-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-muted);
  }

  .sp-pulse-value {
    font-family: 'Montserrat', sans-serif;
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .sp-pulse-value-row {
    display: flex;
    align-items: baseline;
    gap: 0.625rem;
  }

  .sp-pulse-delta {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .sp-pulse-delta--up {
    color: #4ade80;
  }

  .sp-pulse-delta--down {
    color: #ef4444;
  }

  .sp-pulse-breakdown {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    padding-top: 0.25rem;
  }

  .sp-pulse-breakdown-item {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .sp-pulse-breakdown-num {
    font-family: 'Montserrat', sans-serif;
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: -0.03em;
    color: var(--text-primary);
    line-height: 1;
    font-variant-numeric: tabular-nums;
  }

  .sp-pulse-breakdown-tag {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.625rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.13em;
    color: var(--text-muted);
  }

  .sp-pulse-breakdown-div {
    font-size: 1rem;
    color: var(--border-strong);
    font-weight: 300;
    align-self: center;
  }

  /* ===== Sections ===== */
  .sp-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .sp-section-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.625rem;
    font-weight: 700;
    font-variant: all-small-caps;
    letter-spacing: 0.22em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  .sp-editorial {
    margin: 0 0 40px;
    padding: 20px 24px;
    border-left: 2px solid rgba(255, 255, 255, 0.14);
    background: rgba(255, 255, 255, 0.04);
  }

  .sp-editorial-label {
    display: block;
    font-family: 'Montserrat', sans-serif;
    font-size: 0.625rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: 10px;
    text-transform: uppercase;
  }

  .sp-editorial-text {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: 1.0625rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.72);
    margin: 0;
  }

  .sp-section-tag-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
  }

  .sp-section-tag-row .sp-section-tag {
    margin-bottom: 0;
  }

  .sp-section-tag {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    font-variant: all-small-caps;
    letter-spacing: 0.18em;
    color: rgba(255, 255, 255, 0.55);
    text-transform: uppercase;
    margin: 0;
    cursor: help;
    text-decoration: underline dotted rgba(255, 255, 255, 0.25);
  }

  .sp-info-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    cursor: help;
  }

  .sp-info-trigger {
    font-size: 0.8rem;
    color: var(--text-muted);
    cursor: default;
    line-height: 1;
    user-select: none;
    transition: color 0.15s;
  }

  .sp-info-trigger:hover {
    color: var(--accent);
  }

  .sp-info-tooltip {
    display: none;
    position: absolute;
    left: 50%;
    bottom: calc(100% + 10px);
    transform: translateX(-50%);
    width: 320px;
    background: var(--bg-elevated, #111);
    border: 1px solid var(--accent);
    padding: 16px 18px;
    z-index: 100;
    pointer-events: none;
  }

  .sp-info-wrap:hover .sp-info-tooltip {
    display: block;
  }

  .sp-tooltip-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin: 0 0 10px;
    text-transform: uppercase;
  }

  .sp-tooltip-eq {
    display: block;
    font-family: 'Courier New', monospace;
    font-size: 0.8rem;
    color: var(--text-primary);
    background: rgba(255,255,255,0.04);
    padding: 8px 10px;
    margin-bottom: 12px;
    white-space: nowrap;
    letter-spacing: 0.03em;
  }

  .sp-tooltip-legend {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 4px 12px;
    margin: 0;
  }

  .sp-tooltip-legend dt {
    font-family: 'Courier New', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--accent);
    align-self: start;
    padding-top: 1px;
  }

  .sp-tooltip-legend dd {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.7rem;
    color: var(--text-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* ===== Signal Cards ===== */
  .sp-signals {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .sp-signals {
      grid-template-columns: 1fr;
    }
  }

  .sp-signal-card {
    background: var(--bg-elevated);
    padding: 1.25rem 1.25rem 1.25rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    border-left: 3px solid transparent;
  }

  .sp-signal-card--rising {
    border-left-color: #4ade80;
  }

  .sp-signal-card--saturating {
    border-left-color: #f87171;
  }

  .sp-signal-card--niches {
    border-left-color: #a78bfa;
  }

  .sp-signal-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .sp-signal-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.6875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--text-primary);
  }

  .sp-signal-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .sp-signal-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    border-bottom: 1px solid var(--border-subtle);
    padding-bottom: 0.5rem;
  }

  .sp-signal-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .sp-signal-tag {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--text-secondary);
    white-space: nowrap;
  }

  .sp-signal-delta {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .sp-signal-delta--up {
    color: #4ade80;
  }

  .sp-signal-delta--down {
    color: #f87171;
  }

  .sp-signal-niche {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.1rem;
  }

  .sp-signal-niche-rate {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    color: #a78bfa;
    font-variant-numeric: tabular-nums;
  }

  .sp-signal-niche-count {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.625rem;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.03em;
  }

  /* ===== Metric FAQ links ===== */
  .sp-metric-link {
    color: inherit;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.2em;
  }

  .sp-metric-link:hover {
    color: var(--accent);
  }

  .sp-metric-q {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1em;
    height: 1em;
    border-radius: 50%;
    border: 1px solid currentColor;
    font-size: 0.65em;
    font-weight: 700;
    opacity: 0.45;
    line-height: 1;
    flex-shrink: 0;
    transition: opacity 0.15s;
  }

  .sp-metric-link:hover .sp-metric-q {
    opacity: 1;
  }

  .sp-wow-link {
    font-size: 0.85em;
    font-weight: 700;
    text-decoration: underline dotted rgba(255, 255, 255, 0.25);
    text-underline-offset: 2px;
  }

  .sp-wow-link:hover {
    text-decoration-color: var(--accent);
  }

  /* ===== Footer Attribution ===== */
  .sp-attribution {
    padding-top: 0.5rem;
    border-top: 1px solid var(--border-subtle);
  }

  .sp-attribution-text {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.5625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
