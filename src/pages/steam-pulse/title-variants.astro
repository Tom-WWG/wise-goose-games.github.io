---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Title Variants Preview"
  description="Internal preview: chart title hierarchy variants for Steam Pulse."
  canonical="https://wisegoosegames.com/steam-pulse/title-variants/"
  ogUrl="https://wisegoosegames.com/steam-pulse/title-variants/"
  ogImage="https://wisegoosegames.com/og-default.png"
  noindex={true}
>
  <main style="padding: 60px 24px; max-width: 860px; margin: 0 auto; display: flex; flex-direction: column; gap: 48px;">
    <h1 style="font-family: Montserrat, sans-serif; font-size: 0.75rem; letter-spacing: 0.12em; color: rgba(255,255,255,0.4); text-transform: uppercase; margin: 0;">Chart Title Hierarchy — Variants</h1>

    <!-- VARIANT A — Typographic Scale -->
    <div>
      <div style="background: var(--bg-elevated); border: 1px solid var(--border-medium); padding: 1.5rem 1.75rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <h2 class="vt-a-title">
              <span class="vt-a-brand">Steam Pulse</span>
              <span class="vt-a-section">Composite Score</span>
              <span class="vt-a-week">Week 12</span>
            </h2>
            <span style="font-family: Montserrat, sans-serif; font-size: 0.6875rem; font-weight: 700; color: #4ade80; background: rgba(74,222,128,0.08); border: 1px solid rgba(74,222,128,0.2); padding: 0.125rem 0.5rem;">+4% WoW</span>
          </div>
          <span style="font-family: Montserrat, sans-serif; font-size: 0.625rem; letter-spacing: 0.05em; color: rgba(255,255,255,0.4); text-transform: uppercase;">WISEGOOSEGAMES.COM/STEAM-PULSE</span>
        </div>
        <div style="height: 1px; background: rgba(255,255,255,0.1); margin-bottom: 1.25rem;"></div>
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <span style="font-family: Montserrat, sans-serif; font-size: 0.875rem; color: #fff; width: 80px;">Puzzle</span>
            <div style="flex: 1; height: 3px; background: rgba(255,255,255,0.08); position: relative;"><div style="position: absolute; left: 0; top: 0; height: 100%; width: 87%; background: #E87A2E;"></div></div>
            <span style="font-family: Montserrat, sans-serif; font-size: 0.875rem; color: rgba(255,255,255,0.4);">87</span>
          </div>
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <span style="font-family: Montserrat, sans-serif; font-size: 0.875rem; color: #fff; width: 80px;">Cozy</span>
            <div style="flex: 1; height: 3px; background: rgba(255,255,255,0.08); position: relative;"><div style="position: absolute; left: 0; top: 0; height: 100%; width: 82%; background: #38BDF8;"></div></div>
            <span style="font-family: Montserrat, sans-serif; font-size: 0.875rem; color: rgba(255,255,255,0.4);">82</span>
          </div>
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <span style="font-family: Montserrat, sans-serif; font-size: 0.875rem; color: #fff; width: 80px;">Roguelite</span>
            <div style="flex: 1; height: 3px; background: rgba(255,255,255,0.08); position: relative;"><div style="position: absolute; left: 0; top: 0; height: 100%; width: 71%; background: #A78BFA;"></div></div>
            <span style="font-family: Montserrat, sans-serif; font-size: 0.875rem; color: rgba(255,255,255,0.4);">71</span>
          </div>
        </div>
      </div>
      <p style="font-family: Montserrat, sans-serif; font-size: 0.65rem; letter-spacing: 0.12em; color: rgba(255,255,255,0.3); text-transform: uppercase; margin: 8px 0 0 0;">VARIANT A — Typographic Scale</p>
    </div>

    <!-- VARIANT B — Inline Separators with Color -->
    <div>
      <div style="background: var(--bg-elevated); border: 1px solid var(--border-medium); padding: 1.5rem 1.75rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <h2 class="vt-b-title">
              <span class="vt-b-brand">Steam Pulse</span>
              <span class="vt-b-sep" aria-hidden="true"></span>
              <span class="vt-b-section">Composite Score</span>
              <span class="vt-b-sep vt-b-sep--dim" aria-hidden="true"></span>
              <span class="vt-b-week">Week 12</span>
            </h2>
            <span style="font-family: Montserrat, sans-serif; font-size: 0.6875rem; font-weight: 700; color: #4ade80; background: rgba(74,222,128,0.08); border: 1px solid rgba(74,222,128,0.2); padding: 0.125rem 0.5rem;">+4% WoW</span>
          </div>
          <span style="font-family: Montserrat, sans-serif; font-size: 0.625rem; letter-spacing: 0.05em; color: rgba(255,255,255,0.4); text-transform: uppercase;">WISEGOOSEGAMES.COM/STEAM-PULSE</span>
        </div>
        <div style="height: 1px; background: rgba(255,255,255,0.1); margin-bottom: 1.25rem;"></div>
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <span style="font-family: Montserrat, sans-serif; font-size: 0.875rem; color: #fff; width: 80px;">Puzzle</span>
            <div style="flex: 1; height: 3px; background: rgba(255,255,255,0.08); position: relative;"><div style="position: absolute; left: 0; top: 0; height: 100%; width: 87%; background: #E87A2E;"></div></div>
            <span style="font-family: Montserrat, sans-serif; font-size: 0.875rem; color: rgba(255,255,255,0.4);">87</span>
          </div>
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <span style="font-family: Montserrat, sans-serif; font-size: 0.875rem; color: #fff; width: 80px;">Cozy</span>
            <div style="flex: 1; height: 3px; background: rgba(255,255,255,0.08); position: relative;"><div style="position: absolute; left: 0; top: 0; height: 100%; width: 82%; background: #38BDF8;"></div></div>
            <span style="font-family: Montserrat, sans-serif; font-size: 0.875rem; color: rgba(255,255,255,0.4);">82</span>
          </div>
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <span style="font-family: Montserrat, sans-serif; font-size: 0.875rem; color: #fff; width: 80px;">Roguelite</span>
            <div style="flex: 1; height: 3px; background: rgba(255,255,255,0.08); position: relative;"><div style="position: absolute; left: 0; top: 0; height: 100%; width: 71%; background: #A78BFA;"></div></div>
            <span style="font-family: Montserrat, sans-serif; font-size: 0.875rem; color: rgba(255,255,255,0.4);">71</span>
          </div>
        </div>
      </div>
      <p style="font-family: Montserrat, sans-serif; font-size: 0.65rem; letter-spacing: 0.12em; color: rgba(255,255,255,0.3); text-transform: uppercase; margin: 8px 0 0 0;">VARIANT B — Inline Separators with Color</p>
    </div>

    <!-- VARIANT C — Stacked Two-Line -->
    <div>
      <div style="background: var(--bg-elevated); border: 1px solid var(--border-medium); padding: 1.5rem 1.75rem;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <div class="vt-c-title">
              <p class="vt-c-brand">Steam Pulse</p>
              <p class="vt-c-sub">
                <span class="vt-c-section">Composite Score</span>
                <span class="vt-c-dot">·</span>
                <span class="vt-c-week">Week 12</span>
              </p>
            </div>
            <span style="font-family: Montserrat, sans-serif; font-size: 0.6875rem; font-weight: 700; color: #4ade80; background: rgba(74,222,128,0.08); border: 1px solid rgba(74,222,128,0.2); padding: 0.125rem 0.5rem;">+4% WoW</span>
          </div>
          <span style="font-family: Montserrat, sans-serif; font-size: 0.625rem; letter-spacing: 0.05em; color: rgba(255,255,255,0.4); text-transform: uppercase;">WISEGOOSEGAMES.COM/STEAM-PULSE</span>
        </div>
        <div style="height: 1px; background: rgba(255,255,255,0.1); margin-bottom: 1.25rem;"></div>
        <div style="display: flex; flex-direction: column; gap: 0.75rem;">
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <span style="font-family: Montserrat, sans-serif; font-size: 0.875rem; color: #fff; width: 80px;">Puzzle</span>
            <div style="flex: 1; height: 3px; background: rgba(255,255,255,0.08); position: relative;"><div style="position: absolute; left: 0; top: 0; height: 100%; width: 87%; background: #E87A2E;"></div></div>
            <span style="font-family: Montserrat, sans-serif; font-size: 0.875rem; color: rgba(255,255,255,0.4);">87</span>
          </div>
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <span style="font-family: Montserrat, sans-serif; font-size: 0.875rem; color: #fff; width: 80px;">Cozy</span>
            <div style="flex: 1; height: 3px; background: rgba(255,255,255,0.08); position: relative;"><div style="position: absolute; left: 0; top: 0; height: 100%; width: 82%; background: #38BDF8;"></div></div>
            <span style="font-family: Montserrat, sans-serif; font-size: 0.875rem; color: rgba(255,255,255,0.4);">82</span>
          </div>
          <div style="display: flex; align-items: center; gap: 0.75rem;">
            <span style="font-family: Montserrat, sans-serif; font-size: 0.875rem; color: #fff; width: 80px;">Roguelite</span>
            <div style="flex: 1; height: 3px; background: rgba(255,255,255,0.08); position: relative;"><div style="position: absolute; left: 0; top: 0; height: 100%; width: 71%; background: #A78BFA;"></div></div>
            <span style="font-family: Montserrat, sans-serif; font-size: 0.875rem; color: rgba(255,255,255,0.4);">71</span>
          </div>
        </div>
      </div>
      <p style="font-family: Montserrat, sans-serif; font-size: 0.65rem; letter-spacing: 0.12em; color: rgba(255,255,255,0.3); text-transform: uppercase; margin: 8px 0 0 0;">VARIANT C — Stacked Two-Line</p>
    </div>
  </main>
</BaseLayout>

<style>
  /* Variant A — Typographic Scale */
  .vt-a-title {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0;
    flex-wrap: wrap;
  }
  .vt-a-brand {
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    font-size: 1rem;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }
  .vt-a-section {
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--accent);
    letter-spacing: 0.01em;
  }
  .vt-a-week {
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    font-size: 0.7rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    align-self: center;
  }

  /* Variant B — Inline Separators with Color */
  .vt-b-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    flex-wrap: wrap;
  }
  .vt-b-brand {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }
  .vt-b-sep {
    display: inline-block;
    width: 1px;
    height: 0.85em;
    background: var(--accent);
    opacity: 0.6;
    flex-shrink: 0;
  }
  .vt-b-sep--dim {
    background: var(--text-muted);
    opacity: 0.4;
  }
  .vt-b-section {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    font-size: 1rem;
    color: var(--accent);
    letter-spacing: -0.02em;
  }
  .vt-b-week {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 1rem;
    color: var(--text-muted);
    letter-spacing: -0.01em;
  }

  /* Variant C — Stacked Two-Line */
  .vt-c-title {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    margin: 0;
  }
  .vt-c-brand {
    font-family: 'Montserrat', sans-serif;
    font-weight: 800;
    font-size: 1.05rem;
    color: var(--text-primary);
    letter-spacing: -0.02em;
    margin: 0;
    line-height: 1.1;
  }
  .vt-c-sub {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    margin: 0;
  }
  .vt-c-section {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 0.65rem;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .vt-c-dot {
    font-size: 0.65rem;
    color: var(--text-muted);
    opacity: 0.5;
  }
  .vt-c-week {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 0.65rem;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
</style>
