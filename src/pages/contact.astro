---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.tsx';
import { getSEO, getContactPageSchema, getBreadcrumbSchema, SITE_URL } from '../utils/seo';

const seo = getSEO({
  title: 'Contact — Wise Goose Games',
  description: 'Get in touch with Wise Goose Games for press inquiries, business opportunities, or general questions.',
  canonicalPath: '/contact',
  structuredData: [
    getContactPageSchema('Contact — Wise Goose Games', 'Get in touch with Wise Goose Games for press inquiries, business opportunities, or general questions.', `${SITE_URL}/contact/`),
    getBreadcrumbSchema([
      { name: 'Home', path: '/' },
      { name: 'Contact', path: '/contact/' }
    ])
  ]
});
---

<BaseLayout {...seo}>
  <main class="max-w-6xl mx-auto px-4 pt-32 pb-20">
    <h1 class="font-body font-bold text-4xl md:text-5xl text-center mb-4" data-enter>Get in Touch</h1>
    <p class="font-body text-sm text-accent text-center mb-12" data-enter>
      For press inquiries, please include your outlet name and deadline.
    </p>

    <div data-enter>
      <ContactForm client:visible />
    </div>
  </main>
</BaseLayout>
