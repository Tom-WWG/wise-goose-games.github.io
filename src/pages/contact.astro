---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.tsx';
import { getSEO } from '../utils/seo';

const seo = getSEO({
  title: 'Contact — Wise Goose Games',
  description: 'Get in touch with Wise Goose Games for press inquiries, business opportunities, or general questions.',
  canonicalPath: '/contact',
});
---

<BaseLayout {...seo}>
  <main class="max-w-6xl mx-auto px-4 pt-32 pb-20">
    <h1 class="font-body font-bold text-4xl md:text-5xl text-center mb-4">Get in Touch</h1>
    <p class="font-body text-lg text-text/70 text-center max-w-xl mx-auto mb-4">
      Whether you have questions about our games, press inquiries, or just want to say hello — we'd love to hear from you.
    </p>
    <p class="font-body text-sm text-accent text-center mb-12">
      For press inquiries, please include your outlet name and deadline.
    </p>

    <ContactForm client:visible />
  </main>
</BaseLayout>
