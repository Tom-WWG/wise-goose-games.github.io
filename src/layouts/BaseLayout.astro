---
// src/layouts/BaseLayout.astro
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogType?: string;
  ogUrl: string;
  ogImage: string;
  ogVideo?: string;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogType = 'website',
  ogUrl,
  ogImage,
  ogVideo,
  structuredData,
  noindex = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- Anti-FOUC: set theme before paint -->
  <script is:inline>
    (function() {
      var ct = localStorage.getItem('color-theme') || 'brutalist-dark';
      document.documentElement.setAttribute('data-color-theme', ct);
    })();
  </script>
  <!-- Re-apply theme after ViewTransitions swap -->
  <script is:inline>
    document.addEventListener('astro:after-swap', function() {
      var ct = localStorage.getItem('color-theme') || 'brutalist-dark';
      document.documentElement.setAttribute('data-color-theme', ct);
    });
  </script>

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Wise Goose Games" />
  {noindex && <meta name="robots" content="noindex" />}

  <!-- Security Headers (CSP & X-Content-Type-Options via meta since GitHub Pages lacks HTTP header support) -->
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; img-src 'self' data: https:; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https: wss:; media-src blob: https:; worker-src blob:;" />
  <meta http-equiv="X-Content-Type-Options" content="nosniff" />

  <!-- Favicon -->
  <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon-180x180.png" />
  <meta name="msapplication-TileImage" content="/favicon.png" />

  <!-- Canonical -->
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={ogUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:site_name" content="Wise Goose Games" />

  {ogVideo && (
    <>
      <meta property="og:video" content={ogVideo} />
      <meta property="og:video:secure_url" content={ogVideo} />
      <meta property="og:video:type" content="video/mp4" />
      <meta property="og:video:width" content="1920" />
      <meta property="og:video:height" content="1080" />
    </>
  )}

  <!-- Preconnect for Mux video CDN (game page + devlog video embeds) -->
  <link rel="preconnect" href="https://stream.mux.com" crossorigin />
  <link rel="preconnect" href="https://image.mux.com" crossorigin />

  <!-- Font preloads (self-hosted, eliminates render-blocking external CSS) -->
  <link rel="preload" href="/fonts/montserrat-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/cormorant-garamond-italic-latin.woff2" as="font" type="font/woff2" crossorigin />

  <!-- Structured Data -->
  {structuredData && !Array.isArray(structuredData) && (
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  )}
  {structuredData && Array.isArray(structuredData) && structuredData.map((sd) => (
    <script type="application/ld+json" set:html={JSON.stringify(sd)} />
  ))}

  <slot name="head" />
  <ViewTransitions />

  <style is:global>
    @media (prefers-reduced-motion: no-preference) {
      [data-reveal], [data-enter], [data-enter-detail], [data-animate], [data-word], [data-reveal-content], [data-cta-bottom] {
        opacity: 0;
        will-change: opacity, transform;
      }
      [data-enter], [data-enter-detail], [data-reveal-content], [data-animate="bar"], [data-word], [data-cta-bottom] {
        transform: translateY(20px);
      }
      [data-animate]:not([data-animate="bar"]):not([data-animate="play"]) {
        transform: translateY(40px);
      }
      [data-reveal] {
        transform: translateY(30px);
      }
      [data-animate="play"] {
        transform: none;
      }
      .is-revealed {
        opacity: 1 !important;
        transform: translateY(0) !important;
        transition: opacity 0.6s cubic-bezier(0.215, 0.61, 0.355, 1), transform 0.6s cubic-bezier(0.215, 0.61, 0.355, 1);
      }
    }
  </style>
</head>
<body>
  <Navbar />
  <main class="site-main">
    <slot />
  </main>
  <Footer />

  <!-- GA4 (moved to end of body to avoid blocking LCP) -->
  <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_MEASUREMENT_ID}`} is:inline></script>
  <script is:inline define:vars={{ gaId: import.meta.env.PUBLIC_GA_MEASUREMENT_ID }}>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', gaId);
  </script>

  <!-- GA4 page view on View Transitions navigation -->
  <script is:inline>
    document.addEventListener('astro:page-load', () => {
      if (typeof gtag !== 'undefined') {
        gtag('event', 'page_view', {
          page_location: window.location.href,
        });
      }
    });
  </script>

  <script is:inline>
    document.addEventListener('astro:page-load', function() {
      try {
        var params = new URLSearchParams(window.location.search);
        var keys = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'];
        var utms = {};
        var found = false;
        for (var i = 0; i < keys.length; i++) {
          var val = params.get(keys[i]);
          if (val) { utms[keys[i]] = val; found = true; }
        }
        if (found) {
          sessionStorage.setItem('wgg_utm', JSON.stringify(utms));
          var cleanUrl = window.location.pathname + window.location.hash;
          var remaining = new URLSearchParams(window.location.search);
          for (var j = 0; j < keys.length; j++) { remaining.delete(keys[j]); }
          var qs = remaining.toString();
          if (qs) cleanUrl += '?' + qs;
          window.history.replaceState(null, '', cleanUrl);
        }
      } catch (e) {
        // sessionStorage unavailable: silently ignore
      }
    });
  </script>

  <script is:inline>
    (function() {
      var STORE_DOMAINS = ['store.steampowered.com', 'apps.apple.com', 'play.google.com'];
      var SOURCE = 'wgg_website';

      function getPlatform(href) {
        if (href.indexOf('store.steampowered.com') !== -1) return 'steam';
        if (href.indexOf('apps.apple.com') !== -1) return 'ios';
        if (href.indexOf('play.google.com') !== -1) return 'android';
        return null;
      }

      function isStoreLink(el) {
        if (!el || el.tagName !== 'A') return false;
        var href = el.href || '';
        for (var i = 0; i < STORE_DOMAINS.length; i++) {
          if (href.indexOf(STORE_DOMAINS[i]) !== -1) return true;
        }
        return false;
      }

      function getUtmContentFromHref(href, platform) {
        try {
          var url = new URL(href);
          if (platform === 'steam') return url.searchParams.get('utm_content') || '';
          if (platform === 'ios') {
            var ct = url.searchParams.get('ct') || '';
            var parts = ct.split('_');
            return parts.length > 0 ? parts[parts.length - 1] : '';
          }
          if (platform === 'android') {
            var ref = decodeURIComponent(url.searchParams.get('referrer') || '');
            var match = ref.match(/utm_content=([^&]*)/);
            return match ? match[1] : '';
          }
        } catch (e) {}
        return '';
      }

      function enhanceServerRenderedLinks(campaign) {
        var links = document.querySelectorAll('a[href]');
        for (var i = 0; i < links.length; i++) {
          var link = links[i];
          if (link.hasAttribute('data-utm-enhanced')) continue;
          var href = link.href || '';
          var platform = getPlatform(href);
          if (!platform) continue;

          try {
            var url = new URL(href);

            if (platform === 'steam') {
              url.searchParams.set('utm_campaign', campaign);
              link.href = url.toString();
            }

            if (platform === 'ios') {
              var oldCt = url.searchParams.get('ct') || '';
              var prefix = SOURCE + '_';
              var contentPart = oldCt.startsWith(prefix) ? oldCt.slice(prefix.length) : oldCt;
              var newCt = (SOURCE + '_' + campaign + '_' + contentPart).slice(0, 40);
              url.searchParams.set('ct', newCt);
              link.href = url.toString();
            }

            if (platform === 'android') {
              var refParam = url.searchParams.get('referrer') || '';
              var refDecoded = decodeURIComponent(refParam);
              if (refDecoded.indexOf('utm_campaign=') === -1) {
                refDecoded += '&utm_campaign=' + encodeURIComponent(campaign);
              } else {
                refDecoded = refDecoded.replace(/utm_campaign=[^&]*/, 'utm_campaign=' + encodeURIComponent(campaign));
              }
              var baseHref = href.split('referrer=')[0];
              link.href = baseHref + 'referrer=' + encodeURIComponent(refDecoded);
            }

            link.setAttribute('data-utm-enhanced', '');
          } catch (e) {}
        }
      }

      document.addEventListener('astro:page-load', function() {
        try {
          var raw = sessionStorage.getItem('wgg_utm');
          if (raw) {
            var utms = JSON.parse(raw);
            if (utms && utms.utm_campaign) {
              enhanceServerRenderedLinks(utms.utm_campaign);
            }
          }
        } catch (e) {}
      });

      document.addEventListener('click', function(e) {
        var target = e.target;
        while (target && target !== document && target.tagName !== 'A') {
          target = target.parentElement;
        }
        if (!isStoreLink(target)) return;

        var href = target.href || '';
        var platform = getPlatform(href);
        if (!platform) return;

        var placement = getUtmContentFromHref(href, platform);
        var inboundSource = '';
        var inboundMedium = '';
        var inboundCampaign = '';

        try {
          var raw = sessionStorage.getItem('wgg_utm');
          if (raw) {
            var utms = JSON.parse(raw);
            if (utms) {
              inboundSource = utms.utm_source || '';
              inboundMedium = utms.utm_medium || '';
              inboundCampaign = utms.utm_campaign || '';
            }
          }
        } catch (e) {}

        if (typeof gtag !== 'undefined') {
          gtag('event', 'store_click', {
            store_platform: platform,
            link_placement: placement,
            inbound_source: inboundSource,
            inbound_medium: inboundMedium,
            inbound_campaign: inboundCampaign,
            outbound_url: href
          });
        }
      });
    })();
  </script>

  <!-- Page entrance and scroll reveals -->
  <script>
    function setupAnimations() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      // 1. On-load entrance animations (staggered)
      const enterGroups = {
        'data-enter': Array.from(document.querySelectorAll('[data-enter]')),
        'data-enter-detail': Array.from(document.querySelectorAll('[data-enter-detail]')),
        'data-animate-play': Array.from(document.querySelectorAll('[data-animate="play"]')),
        'data-animate-bar': Array.from(document.querySelectorAll('[data-animate="bar"]'))
      };

      requestAnimationFrame(() => {
        enterGroups['data-enter'].forEach((el, i) => {
          setTimeout(() => el.classList.add('is-revealed'), 100 + (i * 80));
        });
        enterGroups['data-enter-detail'].forEach((el, i) => {
          setTimeout(() => el.classList.add('is-revealed'), 150 + (i * 100));
        });
        enterGroups['data-animate-play'].forEach((el) => {
          setTimeout(() => el.classList.add('is-revealed'), 500);
        });
        enterGroups['data-animate-bar'].forEach((el) => {
          setTimeout(() => el.classList.add('is-revealed'), 300);
        });
      });

      // 2. Scroll-triggered animations
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-revealed');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.15, rootMargin: '0px 0px -50px 0px' });

      document.querySelectorAll('[data-reveal], [data-reveal-content], [data-cta-bottom], [data-animate]:not([data-animate="play"]):not([data-animate="bar"])').forEach(el => observer.observe(el));

      // 3. Staggered words in Philosophy
      const philosophyWords = Array.from(document.querySelectorAll('[data-word]'));
      if (philosophyWords.length > 0) {
        const philosophyParent = philosophyWords[0].parentElement;
        if (philosophyParent) {
          const wordObserver = new IntersectionObserver((entries) => {
            if (entries[0].isIntersecting) {
              philosophyWords.forEach((el, i) => {
                setTimeout(() => el.classList.add('is-revealed'), i * 30);
              });
              wordObserver.disconnect();
            }
          }, { threshold: 0.2 });
          wordObserver.observe(philosophyParent);
        }
      }
    }

    setupAnimations();
    document.addEventListener('astro:page-load', setupAnimations);
  </script>
</body>
</html>
