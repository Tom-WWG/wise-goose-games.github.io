---
// src/components/GameDetail.astro
import type { Game } from '../data/games';
import StoreBadges from './StoreBadges.tsx';
import SocialProofComponent from './SocialProof.tsx';
import FAQDrawer from './FAQDrawer.tsx';
import ScreenshotLightbox from './ScreenshotLightbox.tsx';

interface Props {
  game: Game;
}

const { game } = Astro.props;
const screenshots = game.steamAssets.screenshots ?? [];
const screenshotRow1 = screenshots.slice(0, 2);
const screenshotRow2 = screenshots.slice(2);

const row2Cols = screenshotRow2.length === 1 ? 'grid-cols-1'
  : screenshotRow2.length === 2 ? 'grid-cols-1 sm:grid-cols-2'
  : 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-3';

// No string helper needed, we will inline the HTML

---

<div id="game-detail-page">
  {/* ===== CTA BAR: Immediately below trailer ===== */}
  <div data-enter-detail>
    <div class="px-6 md:px-8 py-4" style="background-color: var(--bg-primary); border-top: 2px solid var(--accent);">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
          <h1 class="font-body font-bold text-[18px]" style="color: var(--text-primary); letter-spacing: 1px;">
            {game.title}
          </h1>
          <p class="font-drama italic text-[11px] mt-1" style="color: var(--text-muted);">
            {game.tagline}
          </p>
        </div>
        <StoreBadges client:load game={game} utmContent="detail_top_cta" badgeHeight="h-[40px]" showPrice={true} />
      </div>
    </div>
  </div>

  {/* ===== SCREENSHOTS ROW 1: Edge-to-edge, above first text block ===== */}
  {screenshotRow1.length > 0 && (
    <div class="screenshot-grid" style="margin-top: 2px;">
      <div class={`grid ${screenshotRow1.length === 1 ? 'grid-cols-1' : 'grid-cols-1 sm:grid-cols-2'}`} style="gap: 2px;">
        {screenshotRow1.map((src, i) => (
          <button
            data-enter-detail
            data-lightbox-trigger={i}
            class="block overflow-hidden cursor-zoom-in focus-visible:outline-[var(--accent)] group"
            style="aspect-ratio: 16/10;"
            aria-label={`View screenshot ${i + 1}`}
          >
            <img
              src={src}
              alt={`${game.title} screenshot ${i + 1}`}
              width="2560"
              height="1440"
              class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              loading="lazy"
            />
          </button>
        ))}
      </div>
    </div>
  )}

  {/* ===== CONTENT BLOCK 1: Description + Feature highlights ===== */}
  <section class="px-6 md:px-8 py-12 md:py-16 max-w-4xl mx-auto" style="background-color: var(--bg-primary);">
    {game.longDescription && (
      <div data-reveal-content class="mb-10">
        <p class="font-body text-[15px] md:text-[16px] leading-[1.8]" style="color: var(--text-secondary);">
          {game.longDescription}
        </p>
      </div>
    )}

    {game.featureHighlights && game.featureHighlights.length > 0 && (
      <div data-reveal-content class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {game.featureHighlights.map((highlight) => (
          <div class="p-5" style="background-color: var(--bg-elevated); border-left: 2px solid var(--accent);">
            <h3 class="font-body font-bold text-[13px] uppercase tracking-[1px] mb-2" style="color: var(--text-primary);">
              {highlight.title}
            </h3>
            <p class="font-body text-[13px] leading-[1.6]" style="color: var(--text-muted);">
              {highlight.description}
            </p>
          </div>
        ))}
      </div>
    )}
  </section>

  {/* ===== SCREENSHOTS ROW 2: Visual break between content blocks ===== */}
  {screenshotRow2.length > 0 && (
    <div style="margin-top: 2px;">
      <div class={`grid ${row2Cols}`} style="gap: 2px;">
        {screenshotRow2.map((src, i) => {
          const globalIndex = screenshotRow1.length + i;
          return (
            <button
              data-reveal
              data-lightbox-trigger={globalIndex}
              class="block overflow-hidden cursor-zoom-in focus-visible:outline-[var(--accent)] group"
              style="aspect-ratio: 16/10;"
              aria-label={`View screenshot ${globalIndex + 1}`}
            >
              <img
                src={src}
                alt={`${game.title} screenshot ${globalIndex + 1}`}
                width="2560"
                height="1440"
                class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                loading="lazy"
              />
            </button>
          );
        })}
      </div>
    </div>
  )}

  {/* ===== CONTENT BLOCK 2: Features list + How It Works ===== */}
  {((game.features && game.features.length > 0) || (game.keyMechanics && (game.keyMechanics.core || game.keyMechanics.pieces || game.keyMechanics.progression))) && (
    <section class="px-6 md:px-8 py-12 md:py-16 max-w-4xl mx-auto" style="background-color: var(--bg-primary);">
      {game.features && game.features.length > 0 && (
        <div data-reveal-content class="mb-12">
          <h2 class="font-body font-bold text-[14px] uppercase tracking-[1.5px] mb-4" style="color: var(--text-primary);">
            Features
          </h2>
          <ul class="space-y-2">
            {game.features.map((feature) => (
              <li class="font-body text-[14px] flex items-start gap-3" style="color: var(--text-secondary);">
                <span class="mt-[7px] w-[6px] h-[6px] flex-shrink-0" style="background-color: var(--accent);"></span>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      )}

      {game.keyMechanics && (game.keyMechanics.core || game.keyMechanics.pieces || game.keyMechanics.progression) && (
        <div data-reveal-content>
          <h2 class="font-body font-bold text-[14px] uppercase tracking-[1.5px] mb-4" style="color: var(--text-primary);">
            How It Works
          </h2>
          <div class="space-y-4">
            {game.keyMechanics.core && (
              <div>
                <h3 class="font-body font-semibold text-[12px] uppercase tracking-[1px] mb-1" style="color: var(--accent);">
                  Core Mechanic
                </h3>
                <p class="font-body text-[14px] leading-[1.7]" style="color: var(--text-secondary);">
                  {game.keyMechanics.core}
                </p>
              </div>
            )}
            {game.keyMechanics.pieces && (
              <div>
                <h3 class="font-body font-semibold text-[12px] uppercase tracking-[1px] mb-1" style="color: var(--accent);">
                  Puzzle Pieces
                </h3>
                <p class="font-body text-[14px] leading-[1.7]" style="color: var(--text-secondary);">
                  {game.keyMechanics.pieces}
                </p>
              </div>
            )}
            {game.keyMechanics.progression && (
              <div>
                <h3 class="font-body font-semibold text-[12px] uppercase tracking-[1px] mb-1" style="color: var(--accent);">
                  Progression
                </h3>
                <p class="font-body text-[14px] leading-[1.7]" style="color: var(--text-secondary);">
                  {game.keyMechanics.progression}
                </p>
              </div>
            )}
          </div>
        </div>
      )}
    </section>
  )}

  {/* ===== SOCIAL PROOF: Above final CTA ===== */}
  {game.socialProof && (
    <div data-reveal-content>
      <SocialProofComponent client:visible socialProof={game.socialProof} />
    </div>
  )}

  {/* ===== FINAL CTA: Centered, below screenshots ===== */}
  <div data-cta-bottom>
    <div class="px-6 md:px-8 py-4" style="background-color: var(--bg-primary); border-top: 2px solid var(--accent);">
      <div class="flex flex-col items-center text-center gap-4">
        <div>
          <h2 class="font-body font-bold text-[16px]" style="color: var(--text-primary); letter-spacing: 1px;">
            {game.title}
          </h2>
          <p class="font-drama italic text-[11px] mt-1" style="color: var(--text-muted);">
            Available now on Steam, iOS, and Android
          </p>
        </div>
        <StoreBadges client:visible game={game} utmContent="detail_bottom_cta" badgeHeight="h-[48px]" showPrice={false} />
      </div>
    </div>
  </div>

  {/* ===== FAQ DRAWER: Below final CTA, unobtrusive ===== */}
  {game.faq && game.faq.length > 0 && (
    <FAQDrawer client:visible faqs={game.faq} />
  )}

  {/* ===== LIGHTBOX ===== */}
  <ScreenshotLightbox client:load screenshots={screenshots} gameTitle={game.title} />
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll('[data-lightbox-trigger]').forEach(btn => {
      // Prevent attaching multiple listeners during Astro View Transitions
      if (btn.hasAttribute('data-lightbox-attached')) return;
      btn.setAttribute('data-lightbox-attached', 'true');
      
      btn.addEventListener('click', () => {
        const index = parseInt(btn.getAttribute('data-lightbox-trigger')!);
        window.dispatchEvent(new CustomEvent('open-lightbox', { detail: { index } }));
      });
    });
  });
</script>
