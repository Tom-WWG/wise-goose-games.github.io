---
// src/components/animations/SonarAnimation.astro
---

<div class="sonar-wrap" id="sonar-anim">
  <div class="sonar-grid" id="sonar-grid"></div>
</div>

<style>
  .sonar-wrap { width: 100%; max-width: 390px; margin: 0 auto; }
  .sonar-grid { width: 100%; }
</style>

<script>
  import { GridAnimationEngine } from './GridAnimationEngine.js';

  function initSonar() {
    const container = document.getElementById('sonar-grid');
    if (!container) return;

    const engine = new GridAnimationEngine(container, {
      cols: 9,
      rows: 9,
      speed: 130,
      loop: false,
    });

    engine.setTile(4, 4, { type: 'origin' });

    // Layout — blocked cells
    const BLOCKED_TILES = [
      [2,2],[2,3],[2,5],[2,6],
      [3,2],[3,6],
      [5,2],[5,6],
      [6,2],[6,3],[6,5],[6,6],
    ];
    BLOCKED_TILES.forEach(([r, c]) => engine.setTile(r, c, { type: 'blocked' }));
    const BLOCKED = new Set(BLOCKED_TILES.map(([r, c]) => `${r},${c}`));

    // Seeded PRNG (mulberry32) — seed once per page load
    function mulberry32(seed) {
      return function() {
        seed |= 0; seed = seed + 0x6D2B79F5 | 0;
        let t = Math.imul(seed ^ seed >>> 15, 1 | seed);
        t = t + Math.imul(t ^ t >>> 7, 61 | t) ^ t;
        return ((t ^ t >>> 14) >>> 0) / 4294967296;
      };
    }
    const rand = mulberry32(Math.random() * 0xFFFFFFFF | 0);

    // Pick a random exit, avoiding origin, cells too close, and the previous exit
    function pickExit(prevExit) {
      let r, c;
      do {
        r = Math.floor(rand() * 9);
        c = Math.floor(rand() * 9);
      } while (
        (r === 4 && c === 4) ||
        BLOCKED.has(`${r},${c}`) ||
        Math.abs(r - 4) + Math.abs(c - 4) < 3 ||
        (prevExit && r === prevExit[0] && c === prevExit[1])
      );
      return [r, c];
    }

    // Self-contained BFS from origin (4,4) to target
    function findPath(targetR, targetC) {
      const ROWS = 9, COLS = 9;
      const visited = new Set();
      const parent = new Map();
      const queue = [[4, 4]];
      visited.add('4,4');

      while (queue.length > 0) {
        const [r, c] = queue.shift();
        if (r === targetR && c === targetC) {
          const path = [];
          let key = `${targetR},${targetC}`;
          while (key) {
            const [kr, kc] = key.split(',').map(Number);
            path.unshift([kr, kc]);
            key = parent.get(key) ?? null;
          }
          return path;
        }
        for (const [dr, dc] of [[-1,0],[1,0],[0,-1],[0,1]]) {
          const nr = r + dr, nc = c + dc;
          if (nr < 0 || nr >= ROWS || nc < 0 || nc >= COLS) continue;
          const key = `${nr},${nc}`;
          if (visited.has(key) || BLOCKED.has(key)) continue;
          visited.add(key);
          parent.set(key, `${r},${c}`);
          queue.push([nr, nc]);
        }
      }
      return [[4,4],[targetR,targetC]]; // fallback
    }

    let running = false;
    let loopActive = false;
    let currentExit = null;
    let cancelCurrentLoop = null; // call this to unblock any awaiting runLoop

    function stopAnimation() {
      running = false;
      engine.stop();
      if (cancelCurrentLoop) { cancelCurrentLoop(); cancelCurrentLoop = null; }
    }

    async function runLoop() {
      loopActive = true;

      // Cancellation promise — resolved externally by stopAnimation()
      let cancelResolve;
      const cancelled = new Promise(r => { cancelResolve = r; });
      cancelCurrentLoop = () => cancelResolve();

      try {
        while (running) {
          const [er, ec] = pickExit(currentExit);

          // Place new exit (old was cleared at end of previous iteration)
          currentExit = [er, ec];
          engine.setTile(er, ec, { type: 'exit' });

          // Rebuild phases with fresh path
          engine.clearPhases();
          engine.addPhase({ type: 'wavefront', origin: [4, 4], speed: 175 });
          engine.addPhase({ type: 'path',    cells: findPath(er, ec), speed: 40 });
          engine.addPhase({ type: 'recolor', to: 'path-success' });
          engine.addPhase({ type: 'pause',   duration: 2800 });
          engine.addPhase({ type: 'reset' });

          // Race against cancellation so stop() always unblocks this await
          await Promise.race([engine.play(), cancelled]);
          if (!running) break;

          // Clear exit in the same frame reset completed (no setTimeout delay)
          engine.setTile(er, ec, { type: '' });
          currentExit = null;
        }
      } finally {
        // Clean up any tile left behind if stopped mid-animation
        if (currentExit) {
          engine.setTile(currentExit[0], currentExit[1], { type: '' });
          currentExit = null;
        }
        cancelCurrentLoop = null;
        loopActive = false;
      }
    }

    // IntersectionObserver autoplay
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            running = true;
            if (!loopActive) runLoop();
          } else {
            stopAnimation();
          }
        });
      },
      { threshold: 0.3 }
    );

    observer.observe(document.getElementById('sonar-anim'));
  }

  // Handle both initial page load and Astro view transitions
  document.addEventListener('astro:page-load', initSonar);
  if (document.readyState !== 'loading') initSonar();
</script>
