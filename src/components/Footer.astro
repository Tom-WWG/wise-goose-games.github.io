---
// src/components/Footer.astro
---

<footer class="bg-deep-dark text-gray-300 rounded-t-[4rem] mt-20">
  <div class="max-w-6xl mx-auto px-8 py-16 grid grid-cols-1 md:grid-cols-3 gap-12">
    <!-- Column 1: Brand -->
    <div>
      <p class="font-body font-bold text-white text-lg mb-2">Wise Goose Games</p>
      <p class="font-body text-sm text-gray-400">Thoughtfully Crafted Games</p>
    </div>

    <!-- Column 2: Nav Links -->
    <div>
      <p class="font-body font-semibold text-white text-sm uppercase tracking-wider mb-4">Navigate</p>
      <nav class="flex flex-col gap-2">
        <a href="/" class="text-gray-400 hover:text-white text-sm">Home</a>
        <a href="/games" class="text-gray-400 hover:text-white text-sm">Games</a>
        <a href="/contact" class="text-gray-400 hover:text-white text-sm">Contact</a>
      </nav>
    </div>

    <!-- Column 3: Legal -->
    <div>
      <p class="font-body font-semibold text-white text-sm uppercase tracking-wider mb-4">Legal</p>
      <nav class="flex flex-col gap-2">
        <a href="/privacy" class="text-gray-400 hover:text-white text-sm">Privacy Policy</a>
        <a href="/terms" class="text-gray-400 hover:text-white text-sm">Terms of Service</a>
      </nav>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10 max-w-6xl mx-auto px-8 py-6 flex flex-col md:flex-row items-center justify-between gap-4">
    <p class="text-sm text-gray-500">&copy; 2026 Wise Goose Games. All rights reserved.</p>
    <div class="flex items-center gap-2">
      <span class="status-dot"></span>
      <span class="font-mono text-xs text-gray-500">System Operational</span>
    </div>
  </div>
</footer>
